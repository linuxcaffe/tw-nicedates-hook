# nicedates.rc
# version 1.0.3
#
# Human-friendly date formatting for Taskwarrior reports.
#
# INSTALLATION
#   Add to your ~/.taskrc:
#     include ~/.task/config/nicedates.rc
#
# TOGGLE
#   nicedates         (standalone) or   tw nicedates
#   nicedates --status                  show current config
#
#====================================================================
# ACTIVATION
#   nicedates=on      nicedates is active
#   nicedates=off     nicedates is inactive (pass-through only)
#====================================================================

nicedates=on

#====================================================================
# REPORT SELECTION
#
# Controls which reports nicedates transforms.
#
# Syntax:
#   any               start with all known reports
#   -reportname       exclude this report (requires 'any')
#   report1,report2   positive list — only these reports
#
# Examples:
#   any,-info,-all,-latest    all reports except info, all, latest
#   next,list,overdue         only these three reports
#
# Note: 'any' triggers a 'task reports' lookup (cached, see TTL below)
#====================================================================

nice.reports=any,-info,-all,-latest,-long

# Cache TTL for 'task reports' list, in hours (default: 24)
# Increase if startup feels slow; decrease if you add custom reports often
nice.reports-cache-ttl=24

#====================================================================
# DATE FORMAT SETTINGS
#
# Uses Taskwarrior dateformat characters:
#   Y=4-digit year   y=2-digit year   M=2-digit month   m=1-2 digit month
#   D=2-digit day    d=1-2 digit day  b=short month     B=long month
#   A=long weekday   a=short weekday  H=2-digit hour    h=1-2 digit hour
#   N=2-digit min    n=1-2 digit min
#   Use ' to escape literal characters (e.g. 'y for apostrophe+year)
#
# nice.format.present  Labels for yesterday/today/tomorrow (comma-separated)
# nice.format.week     Format for dates 2-7 days away
# nice.format.month    Format for dates later this year
# nice.format.year     Format for dates in other years
# nice.format.time     Format for time portion (when not concealed)
#====================================================================

nice.format.present=Yesterday,Today,Tomorrow
nice.format.week=A
nice.format.month=bm
# ''y: double-apostrophe escape = literal apostrophe + 2-digit year → '26
# (single 'y would produce literal "y" per standard TW escape rules)
nice.format.year=''y
nice.format.time=h:N

#====================================================================
# TIME CONCEALMENT
#
# Comma-separated list of HH:MM:SS times to suppress from display.
# These are typically Taskwarrior's default "no time set" sentinels.
# Time is hidden entirely when matched (date portion still shown).
#====================================================================

nice.conceal-times=00:00:00,23:59:59

#====================================================================
# GLOBAL DATEFORMAT OVERRIDES (optional)
#
# These apply when nicedates is off, or for non-selected reports.
# Uncomment and set as desired.
#====================================================================

#dateformat=Y-M-D
#dateformat.report=
#dateformat.edit=Y-M-D H:N:S
#dateformat.info=Y-M-D H:N:S
#dateformat.annotation=
